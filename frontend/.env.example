# Base URL of the Rani backend API.
# - Local dev: copy this to .env.local and leave the localhost value.
# - Vercel: set VITE_API_URL in the project's Environment Variables to your
#   deployed backend URL (e.g. https://rani-backend.onrender.com). This is a
#   BUILD-TIME variable — Vite inlines it, so redeploy after changing it.
VITE_API_URL=http://localhost:4000
