{
    "services": {
        "frontend": {
            "root": "frontend",
            "framework": "vite",
            "installCommand": "npm install"
        },
        "backend": {
            "root": "backend",
            "installCommand": "npm install"
        }
    },
    "rewrites": [
        { "source": "/api(/.*)?", "destination": { "type": "service", "service": "backend" } },
        { "source": "/(.*)", "destination": { "type": "service", "service": "frontend" } }
    ]
}
